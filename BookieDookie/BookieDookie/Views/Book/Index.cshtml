@model List<BookieDookie.Models.Book>

<link rel="stylesheet" href="~/css/book.css"/>

<div class="bookshelf-container">

    <div class="books-grid">
        @if (!Model.Any())
        {
            <p style="font-family: 'Allura', cursive;
    background: #f3e9dc;
    padding: 25px 35px;
    border-radius: 25px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    transition: transform 0.2s ease;
    font-size: 28px;
    font-weight: 600;
    color: #6b4f4f;">A quiet shelf, waiting for its first story.</p>
        }
        else
        {
            foreach (var book in Model)
            {
                <div class="book-card">
                    <img src="@book.ImageUrl" alt="@book.Title" />

                    <div class="book-info">
                        <h3>@book.Title</h3>
                        <p><strong>Author:</strong> @book.Author</p>
                        <p><strong>Genre:</strong> @book.Genre</p>
                        <p>@book.Description</p>
                    </div>

                    <div class="book-actions">
                        <a asp-action="Edit" asp-route-id="@book.Id" class="edit-btn">Edit</a>

                        <form asp-action="Delete" asp-route-id="@book.Id" method="post">
                            <button type="submit" class="delete-btn">Delete</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>