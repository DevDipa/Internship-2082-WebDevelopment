@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Reset Password - BookieDookie</title>
    <link rel="stylesheet" href="~/css/login.css" />
</head>

<body>

<div class="login-container">

    <div class="login-card">

        <h1>BookieDookie</h1>
        <h3 class="subtitle">Reset your password</h3>

        <form asp-action="SendResetCode" method="post">

            <input name="email"
                   type="email"
                   placeholder="Enter your registered email"
                   required />

            <button type="submit" class="main-btn">
                Help Me Get a Reset Code
            </button>

        </form>

        <p class="link"
           onclick="window.location.href='/Login/Index'">
            Thank God! I remember
        </p>

    </div>

</div>

</body>
</html>