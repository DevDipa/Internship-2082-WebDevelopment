@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Reset Password - BookieDookie</title>
    <link rel="stylesheet" href="~/css/login.css" />
</head>

<body>

<div class="login-container">

    <div class="login-card">

        <h1>BookieDookie</h1>
        <h3 class="subtitle">Create a new password</h3>

        <p class="info-text">
            Choose a strong password to secure your account.
        </p>

        <form asp-action="ResetPassword" method="post">

            <input name="password"
                   type="password"
                   placeholder="New Password"
                   required />

            <input name="confirmPassword"
                   type="password"
                   placeholder="Confirm Password"
                   required />

            <button type="submit" class="main-btn">
                Reset Password
            </button>

        </form>

        <p class="link"
           onclick="window.location.href='/Login/Index'">
            Back to login
        </p>

    </div>

</div>

</body>
</html>